<script>
// Counters
const cObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (!e.isIntersecting) return;
    const el = e.target, target = +el.dataset.target;
    let count = 0;
    const step = Math.max(target / 50, 1);
    const t = setInterval(() => {
      count = Math.min(count + step, target);
      el.textContent = Math.floor(count);
      if (count >= target) clearInterval(t);
    }, 30);
    cObs.unobserve(el);
  });
}, { threshold: 0.5 });
document.querySelectorAll('[data-target]').forEach(c => cObs.observe(c));

// Exp card reveal
const eObs = new IntersectionObserver(entries => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) {
      setTimeout(() => e.target.classList.add('vis'), i * 140);
      eObs.unobserve(e.target);
    }
  });
}, { threshold: 0.15 });
document.querySelectorAll('.exp-card').forEach(c => eObs.observe(c));

// Filter
function doFilter(tag, btn) {
  document.querySelectorAll('.filt').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.proj-card').forEach(card => {
    card.style.display = (tag === 'all' || (card.dataset.tags || '').includes(tag)) ? '' : 'none';
  });
}

// Pipeline animation
const pipelineEl = document.getElementById('pipeline');
const steps = [
  { icon: '📥', label: 'User submits workflow', status: 'done', sc: 's-done' },
  { icon: '🧠', label: 'Planner agent reasons', status: 'done', sc: 's-done' },
  { icon: '🔀', label: 'Route to sub-agents', status: 'done', sc: 's-done' },
  { icon: '🔍', label: 'Agent A: Web search', status: 'running', sc: 's-run' },
  { icon: '💾', label: 'Agent B: DB query', status: 'running', sc: 's-run' },
  { icon: '📝', label: 'Agent C: Draft output', status: 'waiting', sc: 's-wait' },
  { icon: '✅', label: 'Review & deliver', status: 'waiting', sc: 's-wait' },
];
let pi = 0;
function addPipe() {
  if (pi >= steps.length) { setTimeout(() => { pipelineEl.innerHTML = ''; pi = 0; addPipe(); }, 2500); return; }
  const s = steps[pi++];
  const row = document.createElement('div');
  row.className = 'pipe-row';
  row.innerHTML = `<div class="pipe-step">${s.icon} <span>${s.label}</span><span class="pipe-status ${s.sc}">${s.status}</span></div>`;
  pipelineEl.appendChild(row);
  setTimeout(addPipe, 520);
}
addPipe();
</script>
