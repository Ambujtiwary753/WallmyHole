<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ambuj Tiwari · </title>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #fafaf8;
  --ink: #0a0a0a;
  --card: #ffffff;
  --border: #e8e5e0;
  --orange: #ff5c00;
  --violet: #7b2ff7;
  --lime: #b8ff57;
  --sky: #00c2ff;
  --pink: #ff3cac;
  --muted: #8a8580;
  --orange-soft: rgba(255,92,0,0.08);
  --violet-soft: rgba(123,47,247,0.08);
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body { font-family: 'IBM Plex Mono', monospace; background: var(--bg); color: var(--ink); overflow-x: hidden; }

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 0 48px; height: 64px;
  display: flex; justify-content: space-between; align-items: center;
  background: rgba(250,250,248,0.92); backdrop-filter: blur(20px);
  border-bottom: 1.5px solid var(--border);
}
.nav-logo { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: 1.1rem; letter-spacing: -0.04em; display: flex; align-items: center; gap: 8px; }
.logo-dot { width: 10px; height: 10px; background: var(--orange); border-radius: 50%; animation: blink-dot 2s ease-in-out infinite; }
@keyframes blink-dot { 0%,100%{transform:scale(1);background:var(--orange);} 50%{transform:scale(1.4);background:var(--violet);} }
.nav-links { display: flex; gap: 32px; list-style: none; }
.nav-links a { color: var(--muted); text-decoration: none; font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; transition: color 0.2s; }
.nav-links a:hover { color: var(--ink); }
.nav-cta { background: var(--ink); color: #fff; padding: 9px 22px; font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; cursor: pointer; transition: all 0.2s; text-decoration: none; border-radius: 2px; }
.nav-cta:hover { background: var(--orange); transform: translateY(-1px); }

/* HERO */
#hero { min-height: 100vh; padding: 120px 48px 80px; display: flex; flex-direction: column; justify-content: center; position: relative; overflow: hidden; }
.shape { position: absolute; border-radius: 50%; pointer-events: none; }
.shape-1 { width: 500px; height: 500px; background: var(--orange); opacity: 0.1; top: -150px; right: -80px; filter: blur(70px); animation: morph1 9s ease-in-out infinite; }
.shape-2 { width: 360px; height: 360px; background: var(--violet); opacity: 0.09; bottom: 40px; left: -80px; filter: blur(60px); animation: morph2 11s ease-in-out infinite; }
.shape-3 { width: 160px; height: 160px; background: var(--lime); opacity: 0.6; top: 100px; right: 260px; border-radius: 0; transform: rotate(20deg); animation: spin3 20s linear infinite; z-index: 0; }
@keyframes morph1 { 0%,100%{border-radius:60% 40% 30% 70%/60% 30% 70% 40%;} 50%{border-radius:30% 60% 70% 40%/50% 60% 30% 60%;} }
@keyframes morph2 { 0%,100%{border-radius:40% 60% 70% 30%/40% 50% 60% 50%;} 50%{border-radius:60% 40% 30% 70%/60% 30% 70% 40%;} }
@keyframes spin3 { to { transform: rotate(380deg); } }

.hero-chip { display: inline-flex; align-items: center; gap: 10px; background: var(--lime); color: var(--ink); padding: 8px 18px; font-size: 0.72rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 32px; border-radius: 100px; position: relative; z-index: 1; animation: popIn 0.6s ease both; }
.hero-name { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: clamp(3.5rem, 9vw, 8rem); line-height: 0.9; letter-spacing: -0.04em; position: relative; z-index: 1; animation: popIn 0.7s 0.1s ease both; margin-bottom: 8px; }
.name-line2 { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
.name-badge { background: var(--orange); color: white; font-size: clamp(1rem, 2vw, 1.6rem); font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; padding: 6px 20px; border-radius: 4px; letter-spacing: -0.02em; display: inline-block; animation: popIn 0.7s 0.2s ease both; }
.hero-role { font-size: 0.85rem; color: var(--muted); letter-spacing: 0.04em; margin-top: 24px; margin-bottom: 20px; position: relative; z-index: 1; animation: popIn 0.7s 0.25s ease both; }
.role-pill { display: inline-block; border: 1.5px solid; padding: 2px 10px; border-radius: 4px; font-size: 0.7rem; margin-left: 8px; }
.rp-violet { border-color: var(--violet); color: var(--violet); background: var(--violet-soft); }
.rp-orange { border-color: var(--orange); color: var(--orange); background: var(--orange-soft); }
.hero-desc { font-size: 0.9rem; line-height: 1.9; color: #555; max-width: 600px; margin-bottom: 40px; position: relative; z-index: 1; animation: popIn 0.7s 0.3s ease both; }
.hero-actions { display: flex; gap: 14px; flex-wrap: wrap; position: relative; z-index: 1; animation: popIn 0.7s 0.35s ease both; }
.btn-bold { background: var(--ink); color: #fff; padding: 14px 34px; font-family: 'Bricolage Grotesque', sans-serif; font-size: 0.9rem; font-weight: 700; cursor: pointer; transition: all 0.2s; text-decoration: none; border-radius: 4px; display: inline-flex; align-items: center; gap: 8px; border: 2px solid var(--ink); }
.btn-bold:hover { background: var(--orange); border-color: var(--orange); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(255,92,0,0.3); }
.btn-outline { background: transparent; color: var(--ink); padding: 14px 34px; font-family: 'Bricolage Grotesque', sans-serif; font-size: 0.9rem; font-weight: 700; cursor: pointer; transition: all 0.2s; text-decoration: none; border-radius: 4px; display: inline-flex; align-items: center; gap: 8px; border: 2px solid var(--border); }
.btn-outline:hover { border-color: var(--violet); color: var(--violet); }
.hero-tags { display: flex; gap: 10px; margin-top: 60px; padding-top: 40px; border-top: 1.5px solid var(--border); overflow-x: auto; scrollbar-width: none; position: relative; z-index: 1; animation: popIn 0.7s 0.4s ease both; }
.hero-tags::-webkit-scrollbar { display: none; }
.hero-tag { flex-shrink: 0; background: var(--card); border: 1.5px solid var(--border); padding: 10px 18px; border-radius: 100px; font-size: 0.72rem; white-space: nowrap; display: flex; align-items: center; gap: 8px; transition: all 0.2s; cursor: default; }
.hero-tag:hover { border-color: var(--orange); color: var(--orange); transform: translateY(-2px); }
@keyframes popIn { from { opacity: 0; transform: translateY(20px) scale(0.97); } to { opacity: 1; transform: translateY(0) scale(1); } }

/* ABOUT */
#about { padding: 100px 48px; background: var(--ink); color: var(--bg); }
.section-label-lime { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--lime); margin-bottom: 16px; display: flex; align-items: center; gap: 10px; }
.section-label-lime::before { content: ''; width: 20px; height: 1.5px; background: var(--lime); }
.section-title-big { font-family: 'Bricolage Grotesque', sans-serif; font-size: clamp(2.5rem, 5vw, 4.5rem); font-weight: 800; letter-spacing: -0.04em; line-height: 0.95; margin-bottom: 60px; }
.hl-orange { color: var(--orange); }
.hl-violet { color: #a78bfa; }
.bento-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.bento-card { background: #141414; border: 1px solid #2a2a2a; border-radius: 12px; padding: 32px; transition: border-color 0.2s, transform 0.2s; position: relative; overflow: hidden; }
.bento-card:hover { border-color: #3a3a3a; transform: translateY(-3px); }
.bento-card.wide { grid-column: span 2; }
.bento-card-label { font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: #555; margin-bottom: 12px; }
.bento-card h3 { font-family: 'Bricolage Grotesque', sans-serif; font-size: 1.4rem; font-weight: 700; margin-bottom: 12px; letter-spacing: -0.02em; }
.bento-card p { font-size: 0.78rem; color: #999; line-height: 1.9; }
.bio-card { background: linear-gradient(135deg, #1a0a00 0%, #141414 100%); border-color: #3d1f00; }
.stat-big { font-family: 'Bricolage Grotesque', sans-serif; font-size: 3.5rem; font-weight: 800; color: var(--lime); line-height: 1; margin-bottom: 4px; letter-spacing: -0.04em; }
.stat-sub { font-size: 0.72rem; color: #666; text-transform: uppercase; letter-spacing: 0.1em; }
.skill-pills { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
.skill-pill { padding: 6px 14px; border-radius: 100px; font-size: 0.68rem; font-weight: 500; border: 1.5px solid; }
.pill-orange { border-color: var(--orange); color: var(--orange); background: rgba(255,92,0,0.08); }
.pill-violet { border-color: #a78bfa; color: #a78bfa; background: rgba(167,139,250,0.08); }
.pill-lime { border-color: var(--lime); color: var(--lime); background: rgba(184,255,87,0.08); }
.pill-sky { border-color: var(--sky); color: var(--sky); background: rgba(0,194,255,0.08); }
.agent-flow { display: flex; flex-direction: column; gap: 10px; margin-top: 16px; }
.flow-node { display: flex; align-items: center; gap: 12px; background: #1e1e1e; border: 1px solid #333; border-radius: 8px; padding: 10px 14px; font-size: 0.72rem; transition: all 0.3s; }
.flow-node:hover { border-color: var(--orange); background: #250d00; }
.node-badge { margin-left: auto; font-size: 0.6rem; padding: 2px 8px; border-radius: 4px; font-weight: 500; }
.badge-active { background: rgba(184,255,87,0.15); color: var(--lime); border: 1px solid rgba(184,255,87,0.3); }
.badge-run { background: rgba(255,92,0,0.12); color: var(--orange); border: 1px solid rgba(255,92,0,0.25); animation: pulse-run 1.2s ease-in-out infinite; }
@keyframes pulse-run { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
.flow-arrow { text-align: center; color: #333; font-size: 0.8rem; }
.values-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 8px; }
.value-item { padding: 16px; background: #1a1a1a; border-radius: 8px; border: 1px solid #333; }
.value-icon { font-size: 1.4rem; margin-bottom: 8px; }
.value-name { font-size: 0.78rem; font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; color: #fff; margin-bottom: 4px; }
.value-desc { font-size: 0.68rem; color: #777; line-height: 1.7; }

/* PROJECTS */
#projects { padding: 100px 48px; }
.section-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 48px; flex-wrap: wrap; gap: 20px; }
.section-label-orange { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--orange); margin-bottom: 12px; display: flex; align-items: center; gap: 10px; }
.section-label-orange::before { content: ''; width: 20px; height: 1.5px; background: var(--orange); }
.section-title-dark { font-family: 'Bricolage Grotesque', sans-serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; letter-spacing: -0.04em; line-height: 1; }
.filter-row { display: flex; gap: 8px; flex-wrap: wrap; }
.filt { background: transparent; border: 1.5px solid var(--border); color: var(--muted); padding: 7px 18px; font-family: 'IBM Plex Mono', monospace; font-size: 0.68rem; cursor: pointer; transition: all 0.2s; text-transform: uppercase; letter-spacing: 0.06em; border-radius: 4px; }
.filt:hover, .filt.active { background: var(--ink); border-color: var(--ink); color: #fff; }
.proj-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 20px; }
.proj-card { background: var(--card); border: 1.5px solid var(--border); border-radius: 12px; padding: 28px; transition: all 0.25s; cursor: pointer; position: relative; overflow: hidden; }
.proj-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--orange), var(--violet)); transform: scaleX(0); transition: transform 0.3s; transform-origin: left; }
.proj-card:hover { border-color: #ccc; transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,0.1); }
.proj-card:hover::before { transform: scaleX(1); }
.proj-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; }
.proj-icon { width: 48px; height: 48px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; border: 1.5px solid var(--border); }
.icon-orange { background: rgba(255,92,0,0.08); border-color: rgba(255,92,0,0.2); }
.icon-violet { background: rgba(123,47,247,0.08); border-color: rgba(123,47,247,0.2); }
.icon-lime { background: rgba(184,255,87,0.2); border-color: rgba(100,180,0,0.2); }
.icon-sky { background: rgba(0,194,255,0.08); border-color: rgba(0,194,255,0.2); }
.proj-links-row { display: flex; gap: 6px; }
.plink { width: 30px; height: 30px; border-radius: 6px; border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--muted); text-decoration: none; font-size: 0.78rem; transition: all 0.2s; }
.plink:hover { border-color: var(--ink); color: var(--ink); }
.proj-name { font-family: 'Bricolage Grotesque', sans-serif; font-size: 1.25rem; font-weight: 700; margin-bottom: 8px; letter-spacing: -0.02em; }
.proj-desc { font-size: 0.76rem; color: var(--muted); line-height: 1.8; margin-bottom: 20px; }
.proj-chips { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 20px; }
.chip { font-size: 0.62rem; padding: 3px 10px; border-radius: 4px; font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; border: 1px solid; }
.c-orange { color: var(--orange); border-color: rgba(255,92,0,0.3); background: rgba(255,92,0,0.06); }
.c-violet { color: var(--violet); border-color: rgba(123,47,247,0.3); background: rgba(123,47,247,0.06); }
.c-lime { color: #4a8000; border-color: rgba(100,160,0,0.3); background: rgba(184,255,87,0.15); }
.c-sky { color: #0080aa; border-color: rgba(0,194,255,0.3); background: rgba(0,194,255,0.08); }
.c-pink { color: var(--pink); border-color: rgba(255,60,172,0.3); background: rgba(255,60,172,0.06); }
.proj-footer { display: flex; gap: 16px; padding-top: 16px; border-top: 1px solid var(--border); font-size: 0.68rem; color: var(--muted); }
.proj-card.feat { grid-column: 1 / -1; display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 40px; padding: 40px; align-items: center; }
.feat-label { display: inline-block; background: linear-gradient(90deg, var(--orange), var(--violet)); color: white; font-size: 0.62rem; padding: 4px 12px; border-radius: 4px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500; margin-bottom: 16px; }
.pipeline { background: var(--ink); border-radius: 12px; padding: 24px; height: 280px; overflow: hidden; position: relative; }
.pipeline::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 60px; background: linear-gradient(transparent, var(--ink)); }
.pipe-row { display: flex; align-items: center; gap: 8px; opacity: 0; animation: pipeIn 0.4s ease forwards; margin-bottom: 8px; }
@keyframes pipeIn { to { opacity: 1; } }
.pipe-step { background: #1e1e1e; border: 1px solid #333; border-radius: 6px; padding: 8px 12px; font-size: 0.7rem; color: #bbb; white-space: nowrap; display: flex; align-items: center; gap: 8px; width: 100%; }
.pipe-status { margin-left: auto; font-size: 0.6rem; padding: 2px 7px; border-radius: 3px; flex-shrink: 0; }
.s-done { background: rgba(184,255,87,0.12); color: var(--lime); }
.s-run { background: rgba(255,92,0,0.1); color: var(--orange); animation: pulse-run 1.2s ease-in-out infinite; }
.s-wait { background: rgba(255,255,255,0.04); color: #555; }

/* EXPERIENCE */
#experience { padding: 100px 48px; background: var(--ink); color: var(--bg); }
.exp-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.exp-card { background: #141414; border: 1px solid #2a2a2a; border-radius: 12px; padding: 32px; position: relative; overflow: hidden; opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease, border-color 0.2s; }
.exp-card::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, var(--orange), var(--violet)); }
.exp-card.vis { opacity: 1; transform: translateY(0); }
.exp-card:hover { border-color: #3a3a3a; }
.exp-period { font-size: 0.68rem; color: var(--orange); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 10px; }
.exp-role { font-family: 'Bricolage Grotesque', sans-serif; font-size: 1.25rem; font-weight: 700; margin-bottom: 4px; letter-spacing: -0.02em; }
.exp-co { font-size: 0.75rem; color: #666; margin-bottom: 16px; }
.exp-desc { font-size: 0.74rem; color: #999; line-height: 1.9; margin-bottom: 20px; }
.exp-wins { display: flex; flex-direction: column; gap: 8px; }
.exp-win { font-size: 0.68rem; display: flex; align-items: flex-start; gap: 8px; color: #bbb; }
.win-dot { color: var(--lime); flex-shrink: 0; }

/* CONTACT */
#contact { padding: 100px 48px; }
.contact-wrap { max-width: 820px; margin: 0 auto; }
.contact-big { font-family: 'Bricolage Grotesque', sans-serif; font-size: clamp(2.5rem, 6vw, 5rem); font-weight: 800; letter-spacing: -0.04em; line-height: 0.95; margin-bottom: 40px; }
.contact-big span { color: var(--orange); }
.contact-row { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 40px; }
.clink { display: flex; align-items: center; gap: 10px; padding: 13px 26px; border: 1.5px solid var(--border); border-radius: 8px; color: var(--ink); text-decoration: none; font-size: 0.78rem; transition: all 0.2s; font-family: 'Bricolage Grotesque', sans-serif; font-weight: 600; }
.clink:hover { border-color: var(--ink); transform: translateY(-2px); box-shadow: 4px 4px 0 var(--ink); }
.clink.primary { background: var(--ink); color: #fff; }
.clink.primary:hover { background: var(--orange); border-color: var(--orange); }
.availability-banner { display: flex; align-items: center; gap: 16px; background: linear-gradient(90deg, rgba(184,255,87,0.1), rgba(184,255,87,0.03)); border: 1.5px solid rgba(184,255,87,0.35); border-radius: 10px; padding: 20px 28px; }
.av-dot { width: 10px; height: 10px; background: #70c000; border-radius: 50%; animation: blink-dot 1.5s ease-in-out infinite; flex-shrink: 0; }
.av-text { font-size: 0.82rem; color: #444; }
.av-text strong { color: var(--ink); }

/* FOOTER */
footer { border-top: 1.5px solid var(--border); padding: 28px 48px; display: flex; justify-content: space-between; align-items: center; font-size: 0.7rem; color: var(--muted); }

::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: var(--orange); }

@media (max-width: 900px) {
  nav { padding: 0 20px; }
  .nav-links { display: none; }
  #hero, #about, #projects, #experience, #contact { padding: 90px 20px 60px; }
  .bento-grid { grid-template-columns: 1fr; }
  .bento-card.wide { grid-column: 1; }
  .exp-grid { grid-template-columns: 1fr; }
  .proj-card.feat { grid-column: 1; grid-template-columns: 1fr; }
  footer { flex-direction: column; gap: 10px; text-align: center; }
}
</style>
</head>
<body>

