    <div class="hero-tag">🔗 Multi-agent Systems</div>
    <div class="hero-tag">📊 Data-Driven Roadmaps</div>
    <div class="hero-tag">🚀 0→1 Launches</div>
  </div>
</section>

<!-- ABOUT -->
<section id="about">
  <div class="section-label-lime">About Me</div>
  <h2 class="section-title-big">I Build Agents That<br><span class="hl-orange">Work</span> While You <span class="hl-violet">Sleep</span></h2>
  <div class="bento-grid">

